rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════
    //  공통 헬퍼 함수
    // ════════════════════════════════════════════════════════════

    // 로그인 여부 확인
    function isAuth() {
      return request.auth != null;
    }

    // 관리자 여부 확인 (hubmission@gmail.com 또는 admins 컬렉션에 등록된 유저)
    function isAdmin() {
      return isAuth() && (
        request.auth.token.email == "hubmission@gmail.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // 본인 여부 확인
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // ════════════════════════════════════════════════════════════
    //  1. users — 사용자 프로필
    //  읽기: 전체 공개 | 생성: 로그인 | 수정: 본인 또는 관리자 | 삭제: 본인 또는 관리자
    // ════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  2. routes — 플로깅 경로 기록
    //  읽기: 전체 공개 | 생성: 로그인 | 수정: 작성자 또는 관리자 | 삭제: 관리자
    // ════════════════════════════════════════════════════════════
    match /routes/{docId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  3. events — 플로깅 이벤트
    //  읽기: 전체 공개 | 생성: 로그인 | 수정: 주최자 또는 관리자 | 삭제: 주최자 또는 관리자
    // ════════════════════════════════════════════════════════════
    match /events/{docId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth() &&
        (resource.data.hostUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin() ||
        (isAuth() && resource.data.hostUid == request.auth.uid);
    }

    // ════════════════════════════════════════════════════════════
    //  4. banners — 메인 배너 슬라이더
    //  읽기: 전체 공개 | 쓰기: 관리자만
    // ════════════════════════════════════════════════════════════
    match /banners/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  5. partners — 제휴 파트너
    //  읽기: 로그인 | 쓰기: 관리자만
    // ════════════════════════════════════════════════════════════
    match /partners/{partnerId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  6. partner_requests — 파트너 신청
    //  생성: 본인만 | 읽기: 본인 또는 관리자 | 수정/삭제: 관리자
    // ════════════════════════════════════════════════════════════
    match /partner_requests/{docId} {
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid;
      allow read: if isAuth() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  7. groups — 1회성 그룹 플로깅 (2시간 만료)
    //  읽기/생성/수정: 로그인 | 삭제: 방장 또는 관리자
    // ════════════════════════════════════════════════════════════
    match /groups/{groupId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() &&
        (resource.data.hostUid == request.auth.uid || isAdmin());
    }

    // ════════════════════════════════════════════════════════════
    //  8. clubs — 플로깅 동아리
    //  읽기: 로그인 | 생성: 로그인
    //  수정: 멤버, 동아리장, 관리자 | 삭제: 동아리장 또는 관리자
    // ════════════════════════════════════════════════════════════
    match /clubs/{clubCode} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid in resource.data.memberUids ||
        request.auth.uid == resource.data.hostUid ||
        request.auth.uid in request.resource.data.memberUids ||
        isAdmin()
      );
      allow delete: if isAuth() &&
        (request.auth.uid == resource.data.hostUid || isAdmin());

      // ── 8-1. clubs > history — 동아리 플로깅 기록
      //  읽기: 멤버만 | 생성: 본인이면서 멤버
      //  수정: 불가 | 삭제: 관리자만 (동아리 삭제 시)
      match /history/{entryId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubCode)).data.memberUids;
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.uid
          && request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubCode)).data.memberUids;
        allow update: if false;
        allow delete: if isAdmin();
      }

      // ── 8-2. clubs > notices — 동아리 알림 메시지
      //  읽기: 멤버만 | 생성: 동아리장만 | 수정(읽음처리): 멤버
      //  삭제: 동아리장 또는 관리자
      match /notices/{noticeId} {
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubCode)).data.memberUids;
        allow create: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/clubs/$(clubCode)).data.hostUid;
        allow update: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/clubs/$(clubCode)).data.memberUids;
        allow delete: if isAdmin() || (request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/clubs/$(clubCode)).data.hostUid);
      }
    }

    // ════════════════════════════════════════════════════════════
    //  9. reward_history — 리워드 사용 내역
    //  읽기: 본인 또는 관리자 | 생성: 본인만 | 수정: 본인 또는 관리자 | 삭제: 관리자
    // ════════════════════════════════════════════════════════════
    match /reward_history/{docId} {
      allow read: if isAuth() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  10. point_history — 포인트 적립/차감 내역
    //  읽기: 본인 또는 관리자 | 생성: 본인만 | 수정/삭제: 관리자
    // ════════════════════════════════════════════════════════════
    match /point_history/{docId} {
      allow read: if isAuth() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  11. settings — 앱 설정 (관리자 전용 쓰기)
    // ════════════════════════════════════════════════════════════
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  12. notices — 앱 전체 공지사항 (메인 페이지 표시용)
    //  읽기: 전체 공개 | 쓰기: 관리자만
    // ════════════════════════════════════════════════════════════
    match /notices/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  13. kakaoUsers — 카카오 로그인 사용자 정보
    //  읽기: 본인 또는 관리자 | 생성/수정: 본인만 | 삭제: 관리자
    // ════════════════════════════════════════════════════════════
    match /kakaoUsers/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin());
      allow create, update: if isAuth() && isOwner(userId);
      allow delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  14. admins — 관리자 목록
    //  읽기: 로그인 | 쓰기: 관리자만
    // ════════════════════════════════════════════════════════════
    match /admins/{userId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  15. rankings — 랭킹 데이터
    //  읽기: 로그인 | 쓰기: 관리자만
    // ════════════════════════════════════════════════════════════
    match /rankings/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  16. shopPurchases — 친환경 쇼핑 구매 내역
    //  생성: 필수 필드 검증 | 읽기/수정: 로그인
    // ════════════════════════════════════════════════════════════
    match /shopPurchases/{docId} {
      allow create: if request.resource.data.keys().hasAll(['productId', 'userId', 'status']);
      allow read, update: if request.auth != null;
    }

    // ════════════════════════════════════════════════════════════
    //  17. shopClicks — 쇼핑 클릭 추적 (익명 허용)
    // ════════════════════════════════════════════════════════════
    match /shopClicks/{docId} {
      allow create: if true;
      allow read: if isAuth() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuth() &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ════════════════════════════════════════════════════════════
    //  18. products — 친환경 쇼핑 상품 목록
    //  읽기: 전체 공개 | 쓰기: 관리자만
    // ════════════════════════════════════════════════════════════
    match /products/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  19. stats — 커뮤니티 통계 (누적 사용자 수 등)
    //  읽기: 전체 공개 | 쓰기: 로그인 (탈퇴 시 카운트 증가용)
    // ════════════════════════════════════════════════════════════
    match /stats/{docId} {
      allow read: if true;
      allow create, update: if isAuth();
    }

    // ════════════════════════════════════════════════════════════
    //  20. deletedAccounts — 탈퇴 계정 해시 (재가입 포인트 어뷰징 방지)
    //  읽기/생성: 로그인 | 수정/삭제: 관리자
    // ════════════════════════════════════════════════════════════
    match /deletedAccounts/{hashId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  21. donations — 후원 기록
    //  읽기: 본인 또는 관리자 | 생성: 로그인
    // ════════════════════════════════════════════════════════════
    match /donations/{docId} {
      allow read: if isAuth() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
    }

    // ════════════════════════════════════════════════════════════
    //  22. certificates — 봉사활동 증명서 발급 기록
    //  읽기: 본인 또는 관리자 | 생성: 본인만 (userId 일치)
    //  수정/삭제: 관리자만 (발급 후 변경 불가)
    //  ※ 발급번호로 진위 확인 시 별도 공개 조회 함수 필요
    // ════════════════════════════════════════════════════════════
    match /certificates/{docId} {
      allow read: if isAuth() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  24. giftHistory — 포인트 선물 이력
    //  읽기: 보낸 사람 또는 받는 사람 또는 관리자 | 생성: 로그인 (트랜잭션 내)
    //  수정/삭제: 관리자
    // ════════════════════════════════════════════════════════════
    match /giftHistory/{docId} {
      allow read: if isAuth() &&
        (resource.data.fromUid == request.auth.uid ||
         resource.data.toUid == request.auth.uid ||
         isAdmin());
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // ════════════════════════════════════════════════════════════
    //  25. ecoActions — 녹색생활 실천 기록 (텀블러, 장바구니 등)
    //  읽기: 본인 또는 관리자 | 생성: 로그인
    //  삭제: 본인 또는 관리자 | 수정: 관리자
    // ════════════════════════════════════════════════════════════
    match /ecoActions/{docId} {
      allow read: if isAuth() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth();
      allow delete: if isAuth() &&
        (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
    }
  }
}
